# =====================================================================
# tf2-bptf-bot — environment template. Copy to .env and fill in.
# Validated at boot by apps/bot/src/config/index.ts (zod).
# =====================================================================

# === core ===
NODE_ENV=development
LOG_LEVEL=info

# === Steam (same account as tf2vault-bot) ===
STEAM_ACCOUNT_NAME=
STEAM_PASSWORD=
STEAM_SHARED_SECRET=
STEAM_IDENTITY_SECRET=

# === bp.tf ===
BPTF_API_KEY=
BPTF_USER_TOKEN=

# === database (Neon Postgres) ===
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/bptf?sslmode=require

# === redis (local on VPS #2, shared with tf2vault-bot) ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# === coordination with tf2vault-bot ===
TF2VAULT_RESERVE_KEYS=0
TF2VAULT_RESERVE_REFINED=0

# === safety ===
PAPER_TRADING=true                 # Phase 3 guard. No Steam offers while true.
EMERGENCY_STOP=false               # circuit breaker (also /stop in Telegram)

# === strategy ===
BUY_DISCOUNT_PCT=20
SELL_MARKUP_PCT=12
MAX_HOLD_DAYS=7
MAX_POSITION_PER_SKU=3
MAX_DAILY_TRADES=30
DAILY_LOSS_CUTOFF_PCT=10

# === capital baseline ===
STARTING_CAPITAL_REF=117
KEY_TO_REF_FALLBACK=63

# === telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === scanner ===
SCANNER_INTERVAL_SEC=60
WATCHLIST_SEED_SIZE=20

# === bp.tf rate limiting (hard ceiling — do not raise above 60) ===
BPTF_MAX_REQ_PER_MIN=60

# === Phase 2 — Maker (real bp.tf BUY listings) ===
PAPER_LISTINGS=true                # MUST stay true until you flip it. No real listings while true.
LISTING_REFRESH_INTERVAL_SEC=1800  # 30 min
MAX_LISTINGS=30                    # hard cap (free quota ~70; leave headroom)
LISTING_PRICE_DRIFT_PCT=2          # delete+recreate when price drifts more than this %
LISTING_DETAILS_TEMPLATE=Bot offering {priceRef} ref. Send a trade offer with this exact item, the offer will be reviewed.
BPTF_LISTING_DELAY_MS=1100         # delay between listing API calls
