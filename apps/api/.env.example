# apps/api environment.
# Local dev loads this file via `tsx --env-file=.env` (see package.json dev script).
# In production (PM2/VPS) these come from the process environment, same as the bot.

PORT=3001
HOST=127.0.0.1

# Same Neon Postgres URL the bot uses (read-mostly; only soft-deletes/CRUD on
# OurListing + WatchlistEntry are written here).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Comma-separated list of allowed browser origins (the Vite dev server).
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info
