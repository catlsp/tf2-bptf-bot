{
  "name": "@bptf/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --import tsx --env-file=.env src/index.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src"
  },
  "dependencies": {
    "@bptf/db": "workspace:*",
    "@bptf/types": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "fastify": "^4.28.1",
    "fastify-type-provider-zod": "^2.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@bptf/config": "workspace:*",
    "@types/node": "^20.16.11",
    "@types/ws": "^8.5.12",
    "eslint": "^9.13.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0"
  }
}
