{
  "name": "@bptf/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx --max-old-space-size=240 src/server.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dryrun": "tsx src/scripts/dryRunTrade.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@bptf/db": "workspace:*",
    "@bptf/types": "workspace:*",
    "axios": "^1.7.7",
    "bullmq": "^5.21.2",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "steam-totp": "^2.1.2",
    "steam-tradeoffer-manager": "^2.11.5",
    "steam-user": "^5.2.0",
    "steamcommunity": "^3.48.0",
    "tf2": "^4.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/ws": "^8.5.12",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
