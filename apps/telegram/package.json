{
  "name": "@bptf/telegram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bot.ts",
    "start": "node --import tsx --max-old-space-size=120 src/bot.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src"
  },
  "dependencies": {
    "@bptf/db": "workspace:*",
    "@bptf/types": "workspace:*",
    "grammy": "^1.30.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
