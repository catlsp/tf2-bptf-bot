# apps/web (Vite) environment. Copy to .env for local dev.
# For local front-end dev against an API on the VPS, open an SSH tunnel first:
#   ssh -L 3001:127.0.0.1:3001 root@VPS_HOST
# then these localhost URLs reach the tunneled API.

VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001/ws
